{
    "$schema": "https://opencode.ai/config.json",
    "instructions": [
        "AGENTS.md"
    ],
    "watcher": {
        "ignore": [
            "node_modules/**",
            "**/node_modules/**",
            ".next/**",
            "**/.next/**",
            ".git/**",
            "**/.git/**",
            ".agents/**",
            "**/.agents/**",
            ".claude/**",
            "**/.claude/**",
            "skills/**",
            "**/skills/**",
            "history/**",
            "**/history/**",
            ".superpowers/**",
            "**/.superpowers/**",
            ".antigravity/**",
            "**/.antigravity/**",
            "docs/**",
            "**/docs/**",
            "Final prompts/**",
            "**/Final prompts/**",
            ".archive(dont use)/**",
            "**/.archive(dont use)/**",
            "package-lock.json",
            "**/package-lock.json"
        ]
    },
    "compaction": {
        "auto": false
    }
}